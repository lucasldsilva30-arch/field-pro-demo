generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id           String          @id @default(cuid())
  nome         String
  cnpj         String?         @unique
  status       EmpresaStatus   @default(ATIVA)
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt
  dados        DadoPlanilha[]

  @@index([nome])
}

model ChecklistRegistro {
  id                String                  @id @default(cuid())
  deliveryId        String                  @unique
  companyId         String
  employeeId        String?
  employeeName      String
  employeeFunction  String
  employeeCargo     String
  employeeSector    String
  deliveryDate      String
  nextDeadline      String
  nextDate          String
  rubric            String?
  signatureDate     String
  submittedAt       DateTime
  inspectorName     String
  signature         String
  declarationAccept Boolean
  pdfFileName       String
  criadoEm          DateTime                @default(now())
  atualizadoEm      DateTime                @updatedAt
  items             ChecklistRegistroItem[]

  @@index([companyId])
  @@index([submittedAt])
}

model ChecklistRegistroItem {
  id          String            @id @default(cuid())
  itemId       String           @unique
  checklistId  String
  deliveryId   String
  epiId        String
  epiName      String
  quantity     Int
  checklist    ChecklistRegistro @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@index([deliveryId])
}

model DadoPlanilha {
  id           String   @id @default(cuid())
  nome         String
  telefone     String?
  plano        String?
  status       String?
  empresaId    String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  dadosOriginais Json?
  empresa      Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([empresaId, status])
  @@index([empresaId, nome])
}

enum EmpresaStatus {
  ATIVA
  INATIVA
}

